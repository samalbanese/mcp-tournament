{
  "name": "mcp-tournament",
  "version": "0.1.0",
  "description": "AI model evaluation as an MCP server. Multi-judge panels, structured scoring, pluggable domains.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-tournament": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=unit",
    "test:e2e": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=e2e",
    "lint": "eslint src/"
  },
  "keywords": ["mcp", "model-evaluation", "ai-benchmark", "multi-judge", "llm-eval"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.80.0",
    "zod": "^3.24.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "jest": "^30.0.0",
    "@types/jest": "^30.0.0",
    "ts-jest": "^29.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
