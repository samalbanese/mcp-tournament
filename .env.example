# MCP Tournament environment variables
# Copy to .env (or export in your shell / MCP client config): cp .env.example .env

# Required — OpenRouter API key. Default route for EVERY role:
# candidates, all judges, and the synthesizer. Get one at https://openrouter.ai
OPENROUTER_API_KEY=

# Optional — per-role model overrides (all OpenRouter model ids)
# TOURNAMENT_MODEL_PARTICIPANT=deepseek/deepseek-v3.2
# TOURNAMENT_MODEL_SYNTHESIZER=moonshotai/kimi-k2.5
# TOURNAMENT_MODEL_JUDGE_RULES=openai/gpt-5.4-mini

# Optional — where run results are written (default: ./results)
# TOURNAMENT_RESULTS_DIR=
