{
  "name": "mcp-tournament-results-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && node scripts/prepare-build.mjs && tsc -p tsconfig.emit.json && vite build --configLoader native",
    "preview": "vite preview --host",
    "import-run": "node scripts/import-run.mjs"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "5.9.3",
    "vite": "7.3.6"
  }
}
